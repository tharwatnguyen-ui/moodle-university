# Moodle Docker environment variables

# Path to your Moodle codebase (required)
MOODLE_DOCKER_WWWROOT=C:\Users\ASUS\Downloads\moodle-latest-502\moodle

# Database server to use: pgsql, mariadb, mysql, mssql, oracle (required)
MOODLE_DOCKER_DB=pgsql

# PHP version (optional, default: 8.3)
MOODLE_DOCKER_PHP_VERSION=8.3

# Database version (optional, defaults: mysql 8.0, pgsql 16, mariadb 10.7)
MOODLE_DOCKER_DB_VERSION=16

# Web host and port (optional)
MOODLE_DOCKER_WEB_HOST=localhost
MOODLE_DOCKER_WEB_PORT=8000

# Browser for Behat tests (optional, default: firefox)
MOODLE_DOCKER_BROWSER=firefox

# Enable external services like memcached, redis, solr (optional)
# MOODLE_DOCKER_PHPUNIT_EXTERNAL_SERVICES=1

# BigBlueButton mock (optional)
# MOODLE_DOCKER_BBB_MOCK=1

# Compose project name (optional, useful for running multiple instances)
# COMPOSE_PROJECT_NAME=moodle_dev
